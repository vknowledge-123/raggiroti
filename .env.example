OPENAI_API_KEY=your_key_here

# Local / OpenAI-compatible server (Ollama, LM Studio)
# Example Ollama: http://localhost:11434/v1/  (api_key can be any string, e.g. "ollama")
# Example LM Studio: http://localhost:1234/v1/
LLM_BASE_URL=http://localhost:11434/v1/
LLM_API_KEY=ollama
LLM_RULE_EXTRACT_MODEL=qwen2.5:7b-instruct

# Embeddings (optional)
OPENAI_EMBED_MODEL=text-embedding-3-large
OPENAI_RULE_EXTRACT_MODEL=gpt-4.1-mini
RAGGIROTI_DB=./data/raggiroti.sqlite
RULEBOOK_PATH=./rulebook/nexus_ultra_v2.rulebook.json
